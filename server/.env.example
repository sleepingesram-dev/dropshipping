# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
# Postgres connection string. Leave unset to run with the built-in file-backed
# store (server/data/state.json) — good for local dev and first boot.
# DATABASE_URL=postgres://user:pass@host:5432/dropship_os

# ── Shopify (Admin API) ───────────────────────────────────────────────────
# Shopify admin → Settings → Apps → Develop apps → create app → Admin API token.
# Scopes needed: read_orders, read_products, read_customers, read_analytics.
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TikTok Marketing API ──────────────────────────────────────────────────
# ads.tiktok.com → Tools → API access (or a registered developer app).
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_ADVERTISER_ID=

# ── Meta Marketing API ────────────────────────────────────────────────────
# business.facebook.com → Business settings → System users → generate token
# with ads_read. Ad account id is the number after "act_".
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=

# ── CJDropshipping ────────────────────────────────────────────────────────
# app.cjdropshipping.com → My CJ → Authorization → API.
# CJ_API_EMAIL=
# CJ_API_KEY=

# ── AutoDS ────────────────────────────────────────────────────────────────
# AutoDS has no public REST API; the adapter accepts status webhooks at
# POST /api/webhooks/autods and simulates in mock mode. Set a shared secret:
# AUTODS_WEBHOOK_SECRET=

# ── Klaviyo ───────────────────────────────────────────────────────────────
# klaviyo.com → Settings → API keys → Private key (read-only is enough).
# KLAVIYO_API_KEY=
